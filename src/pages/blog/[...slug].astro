---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostContent from "@/components/blog/post/PostContent.astro";
import PostHead from "@/components/seo/PostHead.astro";
import placeholder from "@/assets/post-placeholder.png";
import { getPostData, getPublishedPosts, type Post } from "@/utils/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: getPostData(post).slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
const postData = getPostData(post);
const { Content } = await render(post);
const description = postData.description;
const imageURL = postData.coverImage?.src ?? placeholder.src;
---

<Layout
  title={postData.title}
  {description}
  {imageURL}
  imageAlt={postData.title}
  canonicalURL={`/blog/${postData.slug}/`}
  openGraphType="article"
>
  <PostHead
    slot="head"
    title={postData.title}
    slug={postData.slug}
    {description}
    {imageURL}
    publishedTime={postData.pubDate}
    modifiedTime={postData.updatedDate}
    author={postData.author}
    tags={postData.tags}
  />

  <PostContent
    title={postData.title}
    pubDate={postData.pubDate}
    updatedDate={postData.updatedDate}
    author={postData.author}
    tags={postData.tags}
    coverImage={postData.coverImage}
  >
    <Content />
  </PostContent>
</Layout>
